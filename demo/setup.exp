#!/usr/bin/expect -f
# Fully scripted demo of clawdwa setup ‚ÄĒ no real binary needed.

proc slow_print {text {delay 0.03}} {
    foreach char [split $text ""] {
        puts -nonewline $char
        flush stdout
        after [expr {int($delay * 1000)}]
    }
    puts ""
}

proc prompt_type {prompt response {delay 0.06}} {
    puts -nonewline $prompt
    flush stdout
    after 800
    foreach char [split $response ""] {
        puts -nonewline $char
        flush stdout
        after [expr {int($delay * 1000)}]
    }
    puts ""
}

# Download
slow_print "\$ curl -L https://github.com/makash/clawdwa/releases/latest/download/clawdwa_linux_amd64 -o clawdwa" 0.02
after 500
puts "  % Total    % Received  Transfered    Speed"
after 200
puts "100 27.4M  100 27.4M    0     0  4823k      0  0:00:05  0:00:05 --:--:-- 5102k"
after 600

slow_print "\$ chmod +x clawdwa" 0.04
after 400

slow_print "\$ ./clawdwa setup" 0.04
after 800

puts ""
puts "=== clawdwa setup ==="
puts ""
after 500
puts "Connecting to WhatsApp..."
after 1200

# QR code (encodes https://clawdwa.com)
