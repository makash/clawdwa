[22.152321, "o", "‚úď Bot JID: 919900000000@s.whatsapp.net\r\r\n\r\r\n‚úď Claude binary: /usr/local/bin/claude\r\r\n\r\r\n‚úď Config saved to ~/.config/clawdwa/config.json\r\r\n\r\r\n\r\r\n=== Setup complete! ===\r\r\n\r\r\nBot will respond to messages in 'clawdWA' starting with:\r\r\n  !        e.g. \"! what is recursion?\"\r\r\n  @claude  e.g. \"@claude write a bash script\"\r\r\n\r\r\n"]
